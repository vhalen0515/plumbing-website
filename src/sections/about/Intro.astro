---
import { Image } from 'astro:assets';
import ownerImage from '../../assets/images/owner.jpg';
---

<section class="about-intro r-split">
    <div>
        <div class="eyebrow">ABOUT US</div>
        <h1 class="about-intro__title r-h1">A local family that treats your home like our own</h1>
        <p class="about-intro__lead">
            Valley Line Plumbing started in 1998 with one truck, one plumber, and a simple promise:
            show up on time, do honest work, and charge a fair price. More than two decades later,
            that promise still runs everything we do.
        </p>
        <p class="about-intro__body">
            We&rsquo;re proud to be part of the Central Valley community — the same neighborhoods
            where our team lives, shops, and raises their families. When you call us, you&rsquo;re
            getting neighbors who genuinely care about getting it right.
        </p>
    </div>
    <div class="about-intro__photo">
        <Image
            src={ownerImage}
            alt="Valley Line Plumbing team"
            width={600}
            height={1000}
            loading="eager"
            fetchpriority="high"
        />
    </div>
</section>

<style>
    .about-intro {
        max-width: 1200px;
        margin: 0 auto;
        padding: 72px 32px 60px;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 56px;
        align-items: center;
    }
    .eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        letter-spacing: 0.14em;
        color: #c62828;
        margin-bottom: 14px;
    }
    .about-intro__title {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        font-size: 50px;
        line-height: 1.03;
        letter-spacing: 0.005em;
        color: #17191b;
        margin-bottom: 22px;
        text-wrap: balance;
    }
    .about-intro__lead {
        font-size: 18px;
        line-height: 1.65;
        color: #4a4c50;
        margin-bottom: 18px;
    }
    .about-intro__body {
        font-size: 16px;
        line-height: 1.65;
        color: #5c5e62;
    }

    .about-intro__photo {
        aspect-ratio: 4/5;
        border-radius: 4px;
        border: 1px solid #34363a;
        overflow: hidden;
        padding: 0;
    }

    .about-intro__photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
        display: block;
    }
</style>
