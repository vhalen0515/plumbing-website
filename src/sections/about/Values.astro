---
import { values } from '../../data/about.js';
---

<section class="values">
  <div class="values__head">
    <div class="eyebrow">WHAT WE STAND FOR</div>
    <h2 class="values__heading">The way we do business</h2>
  </div>
  <div class="values__grid r-grid-3">
    {values.map((v) => (
      <div class="value-card" data-reveal>
        <div class="value-card__mark">{v.mark}</div>
        <h3 class="value-card__title">{v.title}</h3>
        <p class="value-card__body">{v.body}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .values { max-width: 1200px; margin: 0 auto; padding: 74px 32px 40px; }
  .values__head { text-align: center; margin-bottom: 44px; }
  .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: .14em; color: #c62828; margin-bottom: 10px; }
  .values__heading { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 38px; color: #17191b; }
  .values__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .value-card { background: #fff; border: 1px solid #e4e2dd; border-radius: 4px; padding: 32px 28px; }
  .value-card__mark { width: 44px; height: 44px; background: #c62828; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #fff; font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 20px; margin-bottom: 18px; }
  .value-card__title { font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 22px; letter-spacing: .02em; color: #17191b; margin-bottom: 10px; }
  .value-card__body { font-size: 15px; line-height: 1.6; color: #5c5e62; }
</style>
