---
import { creds } from '../../data/about.js';
---

<section class="credentials-wrap">
  <div class="credentials r-split">
    <div>
      <h2 class="credentials__heading">Licensed, insured, and accountable</h2>
      <p class="credentials__body">Every job is done to code by credentialed plumbers, and backed by a written warranty. Peace of mind comes standard.</p>
    </div>
    <div class="credentials__grid r-grid-2">
      {creds.map((c) => (
        <div class="cred-item">
          <div class="cred-item__check">&#10003;</div>
          <div class="cred-item__label">{c}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .credentials-wrap { max-width: 1200px; margin: 0 auto; padding: 40px 32px 40px; }
  .credentials { background: #fff; border: 1px solid #e4e2dd; border-radius: 6px; padding: 40px 44px; display: grid; grid-template-columns: 1fr 1.2fr; gap: 48px; align-items: center; }
  .credentials__heading { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 30px; color: #17191b; line-height: 1.1; margin-bottom: 12px; }
  .credentials__body { font-size: 16px; line-height: 1.6; color: #5c5e62; }
  .credentials__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .cred-item { display: flex; gap: 11px; align-items: flex-start; border: 1px solid #ece9e4; border-radius: 4px; padding: 14px 16px; }
  .cred-item__check { flex: none; width: 22px; height: 22px; border-radius: 50%; background: #c62828; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; margin-top: 1px; }
  .cred-item__label { font-family: 'Oswald', sans-serif; font-weight: 500; font-size: 16px; letter-spacing: .02em; color: #17191b; line-height: 1.25; }
</style>
