---
import { servicesDetailed } from '../../data/services.js';
---

<section class="services-grid">
  <div class="services-grid__list r-grid-2">
    {servicesDetailed.map((s) => (
      <div class="service-item" data-reveal>
        <div class="service-item__num">{s.num}</div>
        <div>
          <h3 class="service-item__name">{s.name}</h3>
          <p class="service-item__desc">{s.desc}</p>
          <div class="service-item__tags">
            {s.tags.map((t) => (
              <span class="service-item__tag">{t}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .services-grid { max-width: 1200px; margin: 0 auto; padding: 70px 32px 30px; }
  .services-grid__list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 26px; }
  .service-item { background: #fff; border: 1px solid #e4e2dd; border-radius: 4px; padding: 32px 30px; display: flex; gap: 22px; align-items: flex-start; }
  .service-item__num { flex: none; width: 52px; height: 52px; background: #fbeceb; border: 1px solid #f2cfcd; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 20px; color: #c62828; }
  .service-item__name { font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 23px; letter-spacing: .02em; color: #17191b; margin-bottom: 9px; }
  .service-item__desc { font-size: 15px; line-height: 1.6; color: #5c5e62; margin-bottom: 14px; }
  .service-item__tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .service-item__tag { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .02em; color: #8a5c5a; background: #f6ecec; border-radius: 3px; padding: 5px 10px; }
</style>
