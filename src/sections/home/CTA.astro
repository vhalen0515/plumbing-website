---
import Button from '../../components/ui/Button.astro';
import { site, base } from '../../data/site.js';
---

<section class="cta">
    <h2 class="cta__heading">Got a leak, clog, or cold shower?</h2>
    <p class="cta__body">
        Call now or request a free quote — we&rsquo;ll get a licensed plumber to your door fast.
    </p>
    <div class="cta__buttons">
        <Button href={site.phoneHref} size="lg">CALL {site.phone}</Button>
        <Button href={`${base}contact`} variant="outline-dark" size="lg">REQUEST A QUOTE</Button>
    </div>
</section>

<style>
    .cta {
        max-width: 1200px;
        margin: 0 auto;
        padding: 80px 32px;
        text-align: center;
    }
    .cta__heading {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        font-size: 44px;
        line-height: 1.05;
        color: #17191b;
        margin-bottom: 18px;
        text-wrap: balance;
    }
    .cta__body {
        font-size: 19px;
        color: #5c5e62;
        max-width: 560px;
        margin: 0 auto 32px;
    }
    .cta__buttons {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
    }
</style>
