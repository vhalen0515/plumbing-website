---
import { counties } from '../../data/areas.js';
---

<section class="counties">
  <div class="counties__head">
    <h2 class="counties__heading">All communities we serve</h2>
    <span class="counties__tag">By county</span>
  </div>
  <div class="counties__grid r-grid-4">
    {counties.map((co) => (
      <div class="county-card" data-reveal>
        <div class="county-card__head">
          <div class="county-card__abbr">{co.abbr}</div>
          <h3 class="county-card__name">{co.name}</h3>
        </div>
        <div class="county-card__towns">
          {co.towns.map((t) => (
            <div class="town"><span class="town__dot"></span>{t}</div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .counties { max-width: 1200px; margin: 0 auto; padding: 56px 32px 30px; }
  .counties__head { display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; margin-bottom: 28px; flex-wrap: wrap; }
  .counties__heading { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 32px; color: #17191b; letter-spacing: .01em; }
  .counties__tag { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #8a8880; }
  .counties__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .county-card { background: #fff; border: 1px solid #e4e2dd; border-radius: 4px; padding: 24px 22px; }
  .county-card__head { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .county-card__abbr { width: 34px; height: 34px; background: #17191b; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #ff5a4d; font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 15px; }
  .county-card__name { font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 18px; color: #17191b; letter-spacing: .02em; }
  .county-card__towns { display: flex; flex-direction: column; gap: 7px; }
  .town { font-size: 14px; color: #5c5e62; display: flex; align-items: center; gap: 8px; }
  .town__dot { width: 4px; height: 4px; background: #c9c7c2; border-radius: 50%; flex: none; }
</style>
