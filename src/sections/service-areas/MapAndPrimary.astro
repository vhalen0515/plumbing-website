---
import { Image } from 'astro:assets';
import serviceArea from '../../assets/images/service-area.png';
import { primaryAreas } from '../../data/areas.js';
import { site } from '../../data/site.js';
---

<section class="map-primary r-split">
    <div class="map-card">
        <div class="map-card__frame">
            <div class="map-card__frame">
                <div class="map-card__frame">
                    <Image
                        src={serviceArea}
                        alt="Valley Line Plumbing service area map"
                        loading="lazy"
                    />
                </div>
            </div>
        </div>
        <div class="map-card__footer">
            <span class="map-card__dot"></span>
            Headquarters — {site.address.line1}, {site.address.line2}
        </div>
    </div>
    <div>
        <h2 class="primary-heading">Primary coverage</h2>
        <p class="primary-sub">Same-day and next-day service, no travel surcharge.</p>
        <div class="primary-grid r-grid-2">
            {
                primaryAreas.map((c) => (
                    <div class="primary-item">
                        <span class="primary-item__dot" />
                        <span class="primary-item__name">{c}</span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .map-primary {
        max-width: 1200px;
        margin: 0 auto;
        padding: 64px 32px 20px;
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 44px;
        align-items: stretch;
    }
    .map-card {
        border-radius: 6px;
        border: 1px solid #e4e2dd;
        background: #fff;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .map-card__frame {
        flex: 1;
        aspect-ratio: 4 / 3;
        position: relative;
    }
    .map-card__frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .map-card__footer {
        padding: 16px 22px;
        border-top: 1px solid #ece9e4;
        font-size: 14px;
        color: #5c5e62;
        display: flex;
        align-items: center;
        gap: 9px;
    }
    .map-card__dot {
        width: 12px;
        height: 12px;
        background: #c62828;
        border-radius: 50%;
        display: inline-block;
    }
    .primary-heading {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        font-size: 26px;
        color: #17191b;
        margin-bottom: 6px;
        letter-spacing: 0.02em;
    }
    .primary-sub {
        font-size: 14px;
        color: #5c5e62;
        margin-bottom: 18px;
    }
    .primary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    .primary-item {
        background: #fff;
        border: 1px solid #e4e2dd;
        border-radius: 4px;
        padding: 12px 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .primary-item__dot {
        width: 8px;
        height: 8px;
        background: #c62828;
        border-radius: 50%;
        flex: none;
    }
    .primary-item__name {
        font-family: 'Oswald', sans-serif;
        font-weight: 500;
        font-size: 16px;
        letter-spacing: 0.02em;
        color: #17191b;
    }

    @media (max-width: 700px) {
        .map-primary {
            grid-template-columns: 1fr;
            padding: 40px 20px 20px;
            gap: 28px;
        }
    }
</style>
